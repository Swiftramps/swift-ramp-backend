PORT=4000
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SWAP_CONTRACT_ID=C...your deployed contract ID...

# Secret key (S...) of the address you passed as `admin` to `initialize`.
# This account signs set_rate calls automatically. Keep this out of git.
ORACLE_SECRET_KEY=S...

# currency code -> token contract address, as a JSON string
CURRENCY_TOKENS_JSON={"USD":"C...","NGN":"C...","KES":"C...","GHS":"C...","ZAR":"C...","EUR":"C...","GBP":"C..."}

ORACLE_INTERVAL_MS=300000

# Audit trail (GET /audit/:identity)
# Identity contract emitting the enrolled/cancelled events. Leave unset to
# disable the endpoint; it will report 503 rather than guess a contract.
IDENTITY_CONTRACT_ID=
# How long a synced trail is served from cache before re-checking the chain.
AUDIT_CACHE_TTL_MS=30000
# Ledgers to reach back on the first sync (~7 days).
AUDIT_BACKFILL_LEDGERS=120960

# Security
NODE_ENV=development
# Required in production. Comma-separated origins; whitespace is ignored.
ALLOWED_ORIGINS=https://swiftramp.com,https://app.swiftramp.com
