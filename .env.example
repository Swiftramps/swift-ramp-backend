PORT=4000
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SWAP_CONTRACT_ID=C...your deployed contract ID...

# Secret key (S...) of the address you passed as `admin` to `initialize`.
# This account signs set_rate calls automatically. Keep this out of git.
ORACLE_SECRET_KEY=S...

# currency code -> token contract address, as a JSON string
CURRENCY_TOKENS_JSON={"USD":"C...","NGN":"C...","KES":"C...","GHS":"C...","ZAR":"C...","EUR":"C...","GBP":"C..."}

ORACLE_INTERVAL_MS=300000
